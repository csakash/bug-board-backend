# Server
PORT=4000
# Comma-separated list of allowed front-end origins (local + production)
FRONTEND_URL=http://localhost:5173,https://bug-board-frontend.vercel.app
# Canonical public origin used in emailed invite links. Set to the address a
# recipient can actually open. Production: the deployed frontend URL.
# Local dev: your running frontend (e.g. http://localhost:5173).
APP_URL=https://bug-board-frontend.vercel.app

# Auth
JWT_SECRET=change-me-to-a-long-random-string

# Neon Postgres
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=bugbot
R2_PUBLIC_BASE_URL=

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Resend (project invite emails). When RESEND_API_KEY is unset, invite links are
# logged to the server console instead of emailed, so the flow stays testable.
RESEND_API_KEY=
RESEND_FROM="Bug Board <onboarding@resend.dev>"
